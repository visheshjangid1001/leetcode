   "source": [
    "### Find Minimum In Rotated Sorted Array "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "d4665632",
   "metadata": {},
   "outputs": [],
   "source": [
    "def FindMinimum():\n",
    "    nums = list(map(int, input(\"Enter numbers separated by space: \").split()))\n",
    "    n = len(nums)\n",
    "    mini = float(\"inf\")\n",
    "    for i in range(n):\n",
    "        mini = min(mini,nums[i])\n",
    "    return mini"
   ]
