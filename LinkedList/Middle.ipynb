    "def Middle(self):\n",
    "    n = 0\n",
    "    temp = self.head\n",
    "    while temp is not None:\n",
    "        n+=1\n",
    "        temp = temp.next\n",
    "    temp = self.head\n",
    "    for i in range(0,n):\n",
    "        temp = temp.next\n",
    "    return temp\n"
   ]
